# Python cache
__pycache__/
*.pyc

# Local data & configuration (keeps user tokens/settings local)
data/

# User uploads & media (to avoid pushing large recordings/photos)
uploads/
snapshots/
videos/
music/

# IDE/OS files
.DS_Store
.vscode/
.idea/

# Local AI models (large binary files - download separately)
models/
bin/whisper/*.so*
bin/whisper/whisper-cli

# Piper TTS binary (download separately)
bin/piper/
